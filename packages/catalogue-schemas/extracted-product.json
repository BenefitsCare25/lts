{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://insurance-saas/schemas/extracted-product.json",
  "$comment": "v2: adds declaredPremium, nonEvidenceLimit, multi-parent stacksOnRawCodes, expanded coverBasis (earnings_based, per_employee_flat), PremiumRate.basis enum, bundledWithProductCode, siteCode on entities. All additions are optional — v1 envelopes still validate.",
  "title": "ExtractedProduct",
  "description": "AI-extracted placement-slip data for one (ProductType x Insurer) instance. Every field carries provenance + confidence so the review UI can highlight uncertainty.",
  "type": "object",
  "required": [
    "productTypeCode",
    "insurerCode",
    "header",
    "policyholder",
    "eligibility",
    "plans",
    "premiumRates",
    "benefits"
  ],
  "additionalProperties": false,
  "properties": {
    "productTypeCode": {
      "type": "string",
      "description": "Catalogue ProductType.code, e.g. GTL, GHS, GPA"
    },
    "insurerCode": {
      "type": "string",
      "description": "Insurer.code, e.g. GE_LIFE, TM_LIFE, ZURICH"
    },
    "bundledWithProductCode": {
      "type": ["string", "null"],
      "description": "When this product's premium is rolled into another product's rates (e.g. SP rates listed as 'Part of GHS'). The reconciliation skips this product; the wizard's Rates tab shows a 'bundled' notice."
    },
    "header": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policyNumber", "period"],
      "properties": {
        "policyNumber": { "$ref": "#/definitions/StringField" },
        "period": { "$ref": "#/definitions/PeriodField" },
        "lastEntryAge": { "$ref": "#/definitions/NumberField" },
        "administrationType": { "$ref": "#/definitions/StringField" },
        "currency": { "$ref": "#/definitions/StringField" },
        "declaredPremium": { "$ref": "#/definitions/NumberField" },
        "nonEvidenceLimit": { "$ref": "#/definitions/StringField" }
      }
    },
    "policyholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legalName"],
      "properties": {
        "legalName": { "$ref": "#/definitions/StringField" },
        "uen": { "$ref": "#/definitions/StringField" },
        "address": { "$ref": "#/definitions/StringField" },
        "businessDescription": { "$ref": "#/definitions/StringField" },
        "insuredEntities": {
          "type": "array",
          "items": { "$ref": "#/definitions/PolicyEntityField" }
        }
      }
    },
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "freeText": { "$ref": "#/definitions/StringField" },
        "categories": {
          "type": "array",
          "description": "Basis-of-cover rows: employee categories with headcounts and SI basis",
          "items": { "$ref": "#/definitions/CategoryField" }
        }
      }
    },
    "plans": {
      "type": "array",
      "items": { "$ref": "#/definitions/PlanField" }
    },
    "premiumRates": {
      "type": "array",
      "items": { "$ref": "#/definitions/PremiumRateField" }
    },
    "benefits": {
      "type": "array",
      "items": { "$ref": "#/definitions/BenefitField" }
    },
    "extractionMeta": {
      "description": "Optional metadata block. The runner overrides this with canonical values after the AI call (overallConfidence aggregated from envelopes, extractorVersion = AI_EXTRACTOR_VERSION constant), so the model is not required to populate it.",
      "type": "object",
      "properties": {
        "overallConfidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "extractorVersion": { "type": "string" },
        "envelopeVersion": {
          "type": "string",
          "description": "Schema version written by the runner. 'v2' for envelopes produced after the Phase 1 migration."
        },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "definitions": {
    "SourceRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "Pointer back to the source workbook for evidence-on-hover in the review UI",
      "properties": {
        "sheet": { "type": "string" },
        "cell": { "type": "string", "description": "A1-notation single cell, e.g. C12" },
        "range": { "type": "string", "description": "A1-notation range, e.g. B22:H22" }
      }
    },
    "FieldEnvelope": {
      "type": "object",
      "required": ["confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceRef": { "$ref": "#/definitions/SourceRef" },
        "raw": {
          "description": "Verbatim text from the slip (preserved for audit even after normalization)"
        }
      }
    },
    "StringField": {
      "allOf": [
        { "$ref": "#/definitions/FieldEnvelope" },
        {
          "type": "object",
          "required": ["value"],
          "properties": { "value": { "type": ["string", "null"] } }
        }
      ]
    },
    "NumberField": {
      "allOf": [
        { "$ref": "#/definitions/FieldEnvelope" },
        {
          "type": "object",
          "required": ["value"],
          "properties": { "value": { "type": ["number", "null"] } }
        }
      ]
    },
    "PeriodField": {
      "allOf": [
        { "$ref": "#/definitions/FieldEnvelope" },
        {
          "type": "object",
          "required": ["value"],
          "properties": {
            "value": {
              "type": ["object", "null"],
              "additionalProperties": false,
              "required": ["from", "to"],
              "properties": {
                "from": { "type": "string", "format": "date" },
                "to": { "type": "string", "format": "date" }
              }
            }
          }
        }
      ]
    },
    "PolicyEntityField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["legalName", "confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceRef": { "$ref": "#/definitions/SourceRef" },
        "legalName": { "type": "string" },
        "policyNumber": { "type": ["string", "null"] },
        "address": { "type": ["string", "null"] },
        "isMaster": { "type": "boolean" },
        "headcountEstimate": { "type": ["integer", "null"] },
        "siteCode": {
          "type": ["string", "null"],
          "description": "Branch/facility code (e.g. AMK, TPY, HQ). Distinct from address. Optional."
        }
      }
    },
    "CategoryField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceRef": { "$ref": "#/definitions/SourceRef" },
        "category": {
          "type": "string",
          "description": "raw label, e.g. 'Executive', 'Hay Job Grade B3'"
        },
        "headcount": { "type": ["integer", "null"] },
        "sumInsuredFormula": {
          "type": ["string", "null"],
          "description": "raw formula text, e.g. '24 x LDBMS'"
        },
        "participation": { "type": ["string", "null"] }
      }
    },
    "PlanField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rawCode", "rawName", "code", "name", "coverBasis", "confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceRef": { "$ref": "#/definitions/SourceRef" },
        "rawCode": { "type": "string" },
        "rawName": { "type": "string" },
        "code": {
          "type": "string",
          "description": "Canonical code emitted by normalizer; falls back to rawCode if no mapping"
        },
        "name": { "type": "string", "description": "Canonical/display name" },
        "coverBasis": {
          "type": "string",
          "enum": ["per_cover_tier", "salary_multiple", "fixed_amount", "per_region", "earnings_based", "per_employee_flat"]
        },
        "stacksOnRawCode": {
          "type": ["string", "null"],
          "description": "DEPRECATED v2: use stacksOnRawCodes. Read path lifts this string into [string]; write path uses stacksOnRawCodes."
        },
        "stacksOnRawCodes": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "v2: list of rawCodes this plan stacks on. Empty array = base plan. Supersedes stacksOnRawCode."
        },
        "selectionMode": { "type": "string", "enum": ["broker_default", "employee_flex"] },
        "schedule": {
          "type": "object",
          "description": "Plan-schedule fields keyed per ProductType.planSchema; values may themselves be FieldEnvelopes",
          "properties": {
            "multiplier": {
              "type": ["number", "null"],
              "description": "salary_multiple basis; e.g. 36 for '36 x LDBMS'"
            },
            "sumAssured": {
              "type": ["number", "null"],
              "description": "fixed_amount basis; e.g. 50000 for '$50,000'"
            },
            "ratePerEmployee": {
              "type": ["number", "null"],
              "description": "per_employee_flat basis; e.g. 9.50 for '$9.50 per insured'"
            },
            "dailyRoomBoard": {
              "type": ["number", "null"],
              "description": "Per-cover-tier R&B amount where applicable"
            },
            "endorsements": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            },
            "exclusions": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          },
          "additionalProperties": true
        }
      }
    },
    "PremiumRateField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planRawCode", "confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceRef": { "$ref": "#/definitions/SourceRef" },
        "planRawCode": { "type": "string" },
        "coverTier": {
          "type": ["string", "null"],
          "description": "EO|ES|EC|EF or insurer-specific tier code; null when basis is not per_cover_tier"
        },
        "basis": {
          "type": "string",
          "enum": ["per_thousand_si", "per_unit_earnings", "per_employee", "flat"],
          "default": "per_thousand_si",
          "description": "Which math applies. per_thousand_si: rate * SI / 1000. per_unit_earnings: rate * estimated annual earnings. per_employee: rate * headcount. flat: just the fixed amount."
        },
        "ratePerThousand": { "type": ["number", "null"] },
        "ratePerEarningsUnit": {
          "type": ["number", "null"],
          "description": "Rate when basis is per_unit_earnings (e.g. WICI 0.000095 per S$1 of earnings)"
        },
        "estimatedAnnualEarnings": {
          "type": ["number", "null"],
          "description": "When basis is per_unit_earnings, the estimated annual earnings used for premium calc"
        },
        "fixedAmount": { "type": ["number", "null"] },
        "blockLabel": {
          "type": ["string", "null"],
          "description": "Section label from the rate table (e.g. 'Plan A', 'Employees', 'Class 1')"
        },
        "ageBand": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "from": { "type": "integer" },
            "to": { "type": "integer" }
          }
        }
      }
    },
    "BenefitField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rawName", "name", "confidence"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sourceRef": { "$ref": "#/definitions/SourceRef" },
        "rawName": {
          "type": "string",
          "description": "Verbatim from slip, e.g. 'Hospital R&B' or 'Daily Room Allowance'"
        },
        "name": {
          "type": "string",
          "description": "Canonical name from normalization map; falls back to rawName"
        },
        "description": { "type": ["string", "null"] },
        "limits": {
          "type": "array",
          "description": "Per-plan sub-limits. planRawCode keys back into the plans[] array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["planRawCode"],
            "properties": {
              "planRawCode": { "type": "string" },
              "amount": { "type": ["number", "null"] },
              "unit": {
                "type": ["string", "null"],
                "description": "e.g. 'per disability', 'per year', 'per day'"
              },
              "rawText": { "type": ["string", "null"] }
            }
          }
        },
        "deductible": { "type": ["number", "null"] },
        "coInsurancePct": { "type": ["number", "null"] },
        "waitingPeriodDays": { "type": ["integer", "null"] }
      }
    }
  }
}
