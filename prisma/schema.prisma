// ================================================================
// Insurance SaaS Platform — Prisma schema (Phase 1, v2)
// ================================================================
//
// Canonical reference: docs/PHASE_1_BUILD_PLAN_v2.md §2.
//
// Three-tier model:
//   1. Relational core — fixed-shape tables (this file).
//   2. Product catalogue — JSON Schemas in ProductType.{schema, planSchema}.
//   3. Product instances — JSONB validated against the catalogue on write.
//
// Every tenant-scoped table includes a tenantId column. Postgres
// row-level security policies (added in Story S3) enforce isolation
// at the database layer; application middleware sets
// app.current_tenant_id per request.
// ================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, citext]
}

// ================================================================
// Tenancy
// ================================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  users                User[]
  clients              Client[]
  employeeSchemas      EmployeeSchema[]
  productTypes         ProductType[]
  insurers             Insurer[]
  tpas                 TPA[]
  pools                Pool[]
  extractionDrafts     ExtractionDraft[]
  aiProvider           TenantAiProvider?
  benefitGroupPresets  BenefitGroupPreset[]
  endorsementCatalogue EndorsementCatalogue[]
  exclusionCatalogue   ExclusionCatalogue[]
  placementSlipUploads PlacementSlipUpload[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  role         UserRole
  // Local credentials auth (Phase 1 dev path). Bcrypt hash; nullable so
  // we can later seed users without a password and have them set one
  // via an invite flow, or rely on workosUserId when SSO is wired up.
  passwordHash String?
  // Reserved for the future WorkOS swap. Kept nullable so the column
  // doesn't block dev/staging where local credentials are the auth path.
  workosUserId String?  @unique

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum UserRole {
  TENANT_ADMIN
  CATALOGUE_ADMIN
  BROKER_ADMIN
  CLIENT_HR
  EMPLOYEE
}

// ================================================================
// Global reference data (system-level, NOT tenant-scoped)
// ================================================================

model Country {
  code       String  @id // ISO 3166 alpha-2: "SG", "MY", "US"
  name       String
  uenPattern String? // regex for business registration validation; null = no pattern
}

model Currency {
  code     String @id // ISO 4217: "SGD", "USD"
  name     String
  decimals Int // 2 for SGD, 0 for JPY
}

model Industry {
  code       String  @id // SSIC code: "62010", "47711"
  name       String
  parentCode String?
}

// ================================================================
// Tenant-scoped registries (Screen 0 — system config)
// ================================================================

// EmployeeSchema.fields stores FieldDef[]:
//   {
//     name: "employee.work_pass_type",
//     label: "Work Pass Type",
//     type: "string"|"integer"|"number"|"boolean"|"date"|"enum"|"fk_lookup",
//     enumValues?: string[],
//     min?: number, max?: number,
//     pattern?: string,
//     fkTable?: string,
//     required: boolean,
//     selectableForPredicates: boolean,
//     pii: boolean,
//     tier: "BUILTIN"|"STANDARD"|"CUSTOM",
//     enabled: boolean
//   }
model EmployeeSchema {
  id        String   @id @default(cuid())
  tenantId  String   @unique // one schema per tenant; clients inherit
  version   Int      @default(1)
  fields    Json
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// OperatorLibrary.operators stores [{ code, label, arity }, ...]
// keyed by data type. Seeded once per Story S7.
model OperatorLibrary {
  dataType  String @id // "string" | "integer" | "number" | "boolean" | "date" | "enum"
  operators Json
}

// Per-tenant AI provider configuration (BYOK — bring-your-own-key).
// Each tenant supplies their own Azure AI Foundry credentials via the
// settings UI; the AI extraction layer uses these instead of a shared
// platform key. One row per tenant.
//
// `encryptedKey` is AES-256-GCM ciphertext encoded as
// "v1.<base64(iv ‖ ciphertext ‖ authTag)>" — see
// apps/web/src/server/security/secret-cipher.ts. The plaintext key is
// never stored, never logged, and never returned by any API. The UI
// shows only the last 4 chars (`keyLastFour`) for confirmation.
//
// `provider` reserves room for future providers (anthropic_direct,
// openai_direct) but Phase 1 only ships azure_ai_foundry.
model TenantAiProvider {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  provider       String   @default("azure_ai_foundry")
  endpoint       String // e.g. "https://my-resource.services.ai.azure.com"
  deploymentName String // model deployment name in the Foundry resource
  apiVersion     String   @default("2024-08-01-preview")
  encryptedKey   String
  keyLastFour    String   @db.VarChar(4)
  active         Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  updatedById    String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Insurer {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  code              String // "TM_LIFE", "GE_LIFE", "ZURICH"
  productsSupported String[] // ["GTL", "GHS", "GMM", ...]
  // Per ADR 0004 — re-introduced at S35 for the TPA claims feed pipeline.
  // Wire format the insurer's TPA delivers claims in. Examples:
  // "IHP" (Tokio Marine), "TMLS" (Great Eastern), "DIRECT_API" (Zurich), null.
  claimFeedProtocol String?
  active            Boolean  @default(true)

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  pools  PoolMembership[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model TPA {
  id                  String   @id @default(cuid())
  tenantId            String
  name                String
  code                String // "IHP", "MHC"
  supportedInsurerIds String[]
  feedFormat          String // "CSV_V1", "JSON_API", ...
  active              Boolean  @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

// FIX for: pool/captive arrangements not modelled (STM "Generali Pool — Captive").
model Pool {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  members  PoolMembership[]
  products Product[]

  @@index([tenantId])
}

model PoolMembership {
  id        String @id @default(cuid())
  poolId    String
  insurerId String
  shareBps  Int? // basis points share, null = unspecified

  pool    Pool    @relation(fields: [poolId], references: [id])
  insurer Insurer @relation(fields: [insurerId], references: [id])

  @@unique([poolId, insurerId])
}

model ProductType {
  id              String @id @default(cuid())
  tenantId        String
  code            String // "GTL", "GHS", "GMM", ...
  name            String
  schema          Json // JSON Schema for the product instance fields
  planSchema      Json // JSON Schema for plans of this type, includes stacks_on / selection_mode
  premiumStrategy String // "per_individual_salary_multiple" | "per_individual_fixed_sum" | "per_group_cover_tier" | "per_headcount_flat" | "per_individual_earnings"
  parsingRules    Json? // for Excel parser — selector rules per insurer template
  displayTemplate Json? // for employee portal card rendering
  version         Int    @default(1)

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  products Product[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ================================================================
// Client onboarding (Screens 1–6)
// ================================================================

model Client {
  id                     String       @id @default(cuid())
  tenantId               String
  legalName              String
  tradingName            String?
  uen                    String // ACRA UEN or foreign equivalent
  countryOfIncorporation String // FK to Country.code (loose ref; FK enforced at app layer)
  address                String
  industry               String? // SSIC code
  primaryContactName     String?
  primaryContactEmail    String?
  status                 ClientStatus @default(ACTIVE)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  policies  Policy[]
  employees Employee[]

  @@index([tenantId])
}

enum ClientStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

model Policy {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  versionId Int      @default(1) // optimistic locking
  // How an employee's age-next-birthday is computed for eligibility:
  //   POLICY_START — age at policy start date (Inspro default)
  //   HIRE_DATE    — age at the employee's hire date
  //   AS_AT_EVENT  — recomputed at each enrolment / claim event
  ageBasis  AgeBasis @default(POLICY_START)

  client        Client            @relation(fields: [clientId], references: [id])
  benefitYears  BenefitYear[]
  entities      PolicyEntity[]
  benefitGroups BenefitGroup[]
  exceptions    PolicyException[]
  flexBundles   FlexBundle[]

  @@index([clientId])
}

enum AgeBasis {
  POLICY_START
  HIRE_DATE
  AS_AT_EVENT
}

model BenefitYear {
  id                     String           @id @default(cuid())
  policyId               String
  startDate              DateTime
  endDate                DateTime
  state                  BenefitYearState @default(DRAFT)
  publishedAt            DateTime?
  publishedBy            String?
  // Renewal carry-forward: when set, applyToCatalogue copies the prior
  // year's Enrollment + ProductEligibility rows as the seed for this
  // year. Brokers can override individual rows after copy.
  carryForwardFromYearId String?

  policy           Policy        @relation(fields: [policyId], references: [id])
  products         Product[]
  carryForwardFrom BenefitYear?  @relation("CarryForwardChain", fields: [carryForwardFromYearId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  carryForwardTo   BenefitYear[] @relation("CarryForwardChain")

  @@unique([policyId, startDate])
  @@index([policyId])
  @@index([carryForwardFromYearId])
}

enum BenefitYearState {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// FIX for: per-entity rate overrides not supported.
model PolicyEntity {
  id                String  @id @default(cuid())
  policyId          String
  legalName         String
  policyNumber      String // insurer-issued, may differ per entity
  address           String?
  headcountEstimate Int?
  isMaster          Boolean @default(false)
  rateOverrides     Json? // null = inherit from product/plan; otherwise per-product overrides

  policy Policy @relation(fields: [policyId], references: [id])

  @@unique([policyId, policyNumber])
  @@index([policyId])
}

// FIX for: predicate depth — JSONLogic supports arbitrary nesting; UI exposes raw mode.
model BenefitGroup {
  id          String  @id @default(cuid())
  policyId    String
  name        String
  predicate   Json // JSONLogic expression; can be arbitrarily nested
  description String?

  policy Policy @relation(fields: [policyId], references: [id])

  @@index([policyId])
}

model Product {
  id            String  @id @default(cuid())
  benefitYearId String
  productTypeId String
  insurerId     String
  poolId        String?
  tpaId         String?
  data          Json // validated against ProductType.schema
  versionId     Int     @default(1) // optimistic locking

  benefitYear     BenefitYear          @relation(fields: [benefitYearId], references: [id])
  productType     ProductType          @relation(fields: [productTypeId], references: [id])
  pool            Pool?                @relation(fields: [poolId], references: [id])
  plans           Plan[]
  eligibility     ProductEligibility[]
  premiumRates    PremiumRate[]
  attachments     ProductAttachment[]
  exceptions      PolicyException[]
  flexBundlePlans FlexBundlePlan[]

  @@index([benefitYearId])
  @@index([productTypeId])
}

// FIX for: stacked rider plans (STM Plan C / D).
// FIX for: flex benefits picker (STM Flex S/M/MC/MC2).
model Plan {
  id            String    @id @default(cuid())
  productId     String
  code          String // "P1", "P4", "PA", ...
  name          String
  coverBasis    String // "per_cover_tier" | "salary_multiple" | "fixed_amount" | "per_region"
  stacksOn      String? // Plan ID this plan stacks on top of (null = base plan)
  selectionMode String    @default("broker_default") // "broker_default" | "employee_flex"
  schedule      Json // benefit schedule fields, validated against ProductType.planSchema
  effectiveFrom DateTime? // effective-dated benefit schedules
  effectiveTo   DateTime?

  product         Product           @relation(fields: [productId], references: [id])
  riderOf         Plan?             @relation("PlanRider", fields: [stacksOn], references: [id], onDelete: NoAction, onUpdate: NoAction)
  riders          Plan[]            @relation("PlanRider")
  exceptions      PolicyException[]
  flexBundlePlans FlexBundlePlan[]

  @@unique([productId, code])
  @@index([productId])
}

model ProductEligibility {
  id             String @id @default(cuid())
  productId      String
  benefitGroupId String
  defaultPlanId  String

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, benefitGroupId])
}

model PremiumRate {
  id              String   @id @default(cuid())
  productId       String
  planId          String
  groupId         String? // null = applies to all groups
  coverTier       String? // "EO" | "ES" | "EC" | "EF" — for per_cover_tier basis
  ratePerThousand Decimal? @db.Decimal(12, 4)
  fixedAmount     Decimal? @db.Decimal(14, 2)

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

// ================================================================
// Employees (Screen 7+, post-onboarding)
// ================================================================

model Employee {
  id              String         @id @default(cuid())
  clientId        String
  data            Json // validated against tenant's EmployeeSchema
  status          EmployeeStatus @default(ACTIVE)
  hireDate        DateTime
  terminationDate DateTime?

  client      Client            @relation(fields: [clientId], references: [id])
  dependents  Dependent[]
  enrollments Enrollment[]
  exceptions  PolicyException[]

  @@index([clientId])
}

enum EmployeeStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

model Dependent {
  id         String @id @default(cuid())
  employeeId String
  data       Json
  relation   String // "spouse" | "child" | "parent"

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

model Enrollment {
  id             String    @id @default(cuid())
  employeeId     String
  productId      String
  planId         String
  benefitGroupId String
  coverTier      String? // "EO" | "ES" | "EC" | "EF"
  effectiveFrom  DateTime
  effectiveTo    DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
}

// ================================================================
// Audit + integrations
// ================================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String // "client.created", "policy.published", ...
  entityType String
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

// PlacementSlipUpload now supports two lifecycles:
//   1. Bound upload — broker uploads under an existing client; clientId
//      is set at upload time. (Original Phase 1G behaviour.)
//   2. Orphan upload — broker drops a slip on /admin/clients/new before
//      a client exists; clientId is null until the wizard's Apply step
//      creates the client and back-fills it. The wizard reads/writes
//      via tenantId only during this window.
//
// Both shapes share `tenantId` directly so RLS works without a parent FK
// walk (the parent-FK helper returned null for orphan rows). Existing
// rows are back-filled via the migration's UPDATE statement.
model PlacementSlipUpload {
  id              String   @id @default(cuid())
  tenantId        String
  clientId        String?
  uploadedBy      String
  filename        String
  storageKey      String // Azure Blob / SharePoint key
  storageWebUrl   String? // SharePoint/OneDrive web URL for the file
  insurerTemplate String? // detected template; null if unknown
  parseStatus     String // "PENDING" | "PARSED" | "FAILED" | "REVIEWED" | "APPLIED"
  parseResult     Json?
  issues          Json? // resolved/unresolved issues
  createdAt       DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  extractionDraft ExtractionDraft?

  @@index([tenantId])
  @@index([clientId])
}

// ================================================================
// AI extraction (replaces heuristic parser as primary path)
// ================================================================
//
// One ExtractionDraft per upload. Lifecycle:
//   QUEUED → EXTRACTING → READY → APPLIED
//                       ↘ FAILED
//                       ↘ DISCARDED (user abandons)
//
// `extractedProducts` is `ExtractedProduct[]` validated against
// packages/catalogue-schemas/extracted-product.json. Every leaf is
// `{ value, raw, confidence, sourceRef }` so the review UI can
// surface confidence per field and link back to the source slip.
//
// `progress` shape:
//   { totalProducts, completed,
//     perProduct: { [code]: { stage, error? } } }
//
// `validationIssues` is keyed by product index → Ajv ErrorObject[].
// We attach instead of blocking so the broker can fix-and-apply.
//
// RLS policy mirrors other tenant-scoped tables (Story S3 pattern).
model ExtractionDraft {
  id                String    @id @default(cuid())
  tenantId          String
  uploadId          String    @unique
  status            String // "QUEUED" | "EXTRACTING" | "READY" | "APPLIED" | "DISCARDED" | "FAILED"
  progress          Json
  extractedProducts Json
  validationIssues  Json?
  appliedAt         DateTime?
  appliedById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  upload PlacementSlipUpload @relation(fields: [uploadId], references: [id])

  @@index([tenantId, status])
}

// ================================================================
// Wizard foundation — catalogues, presets, exceptions, bundles
// ================================================================
//
// Tables introduced in 20260430140000_wizard_foundation to support
// the import-first Create Client wizard. All catalogues are tenant-
// scoped (one per broker); bundles and exceptions are policy-scoped.
// IssueType is a system-managed registry — no tenantId.

// Reusable predicate templates per tenant. The wizard's eligibility
// section offers these as quick-add chips so brokers stop re-typing
// "Foreign Workers" / "Bargainable" / "Senior management" on every
// new client. `applicableProductCodes` narrows the chip palette per
// product type (e.g. "Manual worker" only relevant to WICA).
model BenefitGroupPreset {
  id                     String   @id @default(cuid())
  tenantId               String
  name                   String
  description            String?
  predicate              Json // JSONLogic, same shape as BenefitGroup.predicate
  category               String? // STAFF_CLASS | FOREIGN_WORKER | OCCUPATION | GEOGRAPHIC
  applicableProductCodes String[] @default([])
  createdAt              DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
}

// Tenant-scoped endorsement registry. Plans reference codes from
// here in `Plan.schedule.endorsements[]`. Codes (e.g.
// PROLONGED_ILLNESS_EXTENSION) are stable; labels and descriptions
// are tenant-editable. AI extractor maps slip text to codes via the
// catalogue.
model EndorsementCatalogue {
  id                     String   @id @default(cuid())
  tenantId               String
  code                   String
  label                  String
  description            String?
  applicableProductCodes String[] @default([])
  active                 Boolean  @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

// Mirror of EndorsementCatalogue for exclusions (carved-out cover).
// Stored separately so the UI can offer them on different tabs and
// the catalogue admin can curate them independently.
model ExclusionCatalogue {
  id                     String   @id @default(cuid())
  tenantId               String
  code                   String
  label                  String
  description            String?
  applicableProductCodes String[] @default([])
  active                 Boolean  @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
}

// Per-employee carve-outs against a Policy / Product / Plan.
// Matches Inspro's "Employees Above Last Entry Age" grandfather list
// plus future cases (waived underwriting, plan override, etc.).
// `exceptionType` is a string code so new categories don't need a
// migration; surface enum is enforced at the application layer.
model PolicyException {
  id            String    @id @default(cuid())
  policyId      String
  productId     String?
  planId        String?
  employeeId    String
  exceptionType String // GRANDFATHERED_AGE | WAIVED_UNDERWRITING | PLAN_OVERRIDE | ...
  reason        String?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())

  policy   Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  plan     Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([employeeId])
}

// Flex picker bundle composition. The Setup sheet's "Flex S = GTL +
// GPA + GHS2 + SP2" pattern is one row in FlexBundle plus N rows in
// FlexBundlePlan. Employee picks a bundle; enrolment writes one
// Enrollment per bundle plan. Generic — any policy can have flex.
model FlexBundle {
  id          String   @id @default(cuid())
  policyId    String
  code        String // "FLEX_S", "FLEX_M", ...
  name        String
  description String?
  createdAt   DateTime @default(now())

  policy Policy           @relation(fields: [policyId], references: [id], onDelete: Cascade)
  plans  FlexBundlePlan[]

  @@unique([policyId, code])
  @@index([policyId])
}

model FlexBundlePlan {
  id        String @id @default(cuid())
  bundleId  String
  productId String
  planId    String

  bundle  FlexBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  plan    Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([bundleId, productId])
  @@index([bundleId])
}

// File attachments hung off a Product (e.g. broker product summary
// PDF). storageKey is a SharePoint path mirroring PlacementSlipUpload.
// `kind` reserves the column for non-summary attachments later
// (T&Cs, schedule of benefits PDF, claim form).
model ProductAttachment {
  id            String   @id @default(cuid())
  productId     String
  filename      String
  storageKey    String
  storageWebUrl String?
  kind          String   @default("PRODUCT_SUMMARY")
  uploadedBy    String?
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// System-level taxonomy of every issue the wizard / parser / extractor
// can surface. Intentionally has no tenantId — these are platform
// concepts, not tenant data. Brokers see them rendered through one
// generic <IssueResolver> component driven by `suggestedActions`.
//
// Severity here is the *default* — handlers can downgrade per
// occurrence (e.g. PARTIAL_RATE_TABLE is `warning` by default but
// upgrades to `error` if the broker chose "block apply" mode).
model IssueType {
  code             String   @id // e.g. "INSURER_CELL_VS_TEMPLATE_MISMATCH"
  category         String // SOURCE | EXTRACTION | VALIDATION | RECONCILIATION
  defaultSeverity  String // info | warning | error
  label            String
  description      String?
  suggestedActions String[] @default([])
}
