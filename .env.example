# =============================================================
# Insurance SaaS Platform — environment variables
# =============================================================
# Copy this file to .env (gitignored) and fill in real values
# for local development. Production secrets live in Azure Key
# Vault, never in this file.
#
# Markers:
#   [now]   needed for the bootstrap session (Phase 1 pre-stories)
#   [later] populated as the corresponding story lands
# =============================================================

# ----- Database (Postgres 16, via docker-compose) ------------ [now]
# Default credentials match docker-compose.yml. Override only if
# you change the compose file or use a different Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insurance_saas?schema=public

# ----- Cache / job queue (Redis 7, via docker-compose) ------- [now]
# Used by BullMQ once S5 lands. Set now so the connection
# string is in place when workers are enabled.
REDIS_URL=redis://localhost:6379

# ----- Next.js runtime --------------------------------------- [now]
# Public URL the app is reachable at. Used by auth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- WorkOS AuthKit ---------------------------------------- [now — S2]
# Create a WorkOS project at https://dashboard.workos.com:
#   1. Enable AuthKit (https://workos.com/docs/authkit/quickstart)
#   2. Get the API key and Client ID from "API Keys"
#   3. Add http://localhost:3000/api/auth/callback to "Redirect URIs"
#   4. Generate a random 32+ char password for cookie encryption:
#        openssl rand -base64 32
#   5. (Phase 2) Configure Google + Microsoft SSO connections in
#        the dashboard for the dev organization.
#
# Until these are filled in, the app runs with /admin disabled —
# see apps/web/src/server/env.ts for the fallback logic.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ----- SharePoint storage (placement slips, S29) ------------- [later]
# We use SharePoint instead of Azure Blob — same pattern as sister
# project PAD (src/lib/sharepoint.ts). Delegated auth via ROPC
# against a service account whose MFA is disabled. Files land in
# the service account's OneDrive at:
#   /lts-placement-slips/<tenant-slug>/<client-id>/<filename>
#
# When these are blank the upload path falls back to "inline:" —
# parsed result is stored but raw bytes aren't, so re-parse needs
# re-upload. Local dev that doesn't need re-parse can skip this.
#
# Setup:
#   1. Register an app in Azure AD
#   2. Grant delegated Microsoft Graph permission "Files.ReadWrite.All"
#      (admin consent)
#   3. Create a service account user (any licensed M365 user works)
#      and disable MFA on it
#   4. Generate a client secret; populate the four AZURE_* vars below
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SERVICE_ACCOUNT_USERNAME=
AZURE_SERVICE_ACCOUNT_PASSWORD=

# ----- Azure Application Insights ---------------------------- [later — S1]
# Telemetry for production. Local dev leaves this blank.
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ----- Node environment -------------------------------------- [now]
# Set automatically by Next.js in dev/build/start; override only
# for special test runs.
# NODE_ENV=development
