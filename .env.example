# --- Database ---------------------------------------------------------------
# Local Postgres from docker-compose
DATABASE_URL="postgresql://lts:lts@localhost:5432/lts?schema=public"

# --- Redis ------------------------------------------------------------------
# Local Redis from docker-compose (used by BullMQ from S20 onwards)
REDIS_URL="redis://localhost:6379"

# --- WorkOS AuthKit (added in S3) -------------------------------------------
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
WORKOS_REDIRECT_URI="http://localhost:3000/api/auth/callback"
WORKOS_COOKIE_PASSWORD=""

# --- Azure Blob Storage (added in S17) --------------------------------------
AZURE_STORAGE_ACCOUNT=""
AZURE_STORAGE_CONTAINER="placement-slips"
AZURE_STORAGE_CONNECTION_STRING=""

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NODE_ENV is intentionally not set here — Next.js sets it automatically
# (development for `next dev`, production for `next build`/`next start`).
# Setting it in .env breaks production builds.
