{
  "name": "insurance-saas",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-agency white-label insurance brokerage SaaS platform.",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "dev": "pnpm --filter @insurance-saas/web dev",
    "build": "pnpm --filter @insurance-saas/web build",
    "start": "pnpm --filter @insurance-saas/web start",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @insurance-saas/web test:e2e",
    "prisma": "prisma",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
